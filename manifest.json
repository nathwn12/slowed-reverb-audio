{
  "manifest_version": 3,
  "name": "Slowed Reverb Audio",
  "version": "1.0.0",
  "description": "Slow YouTube audio and add built-in reverb locally.",
  "minimum_chrome_version": "116",
  "permissions": [
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://music.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://youtube.com/*",
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": [
        "shared.js",
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["dattorro-worklet.js"],
    "matches": ["https://youtube.com/*", "https://www.youtube.com/*", "https://music.youtube.com/*"]
  }],
  "action": {
    "default_title": "Slowed Reverb Audio",
    "default_popup": "popup.html"
  }
}
